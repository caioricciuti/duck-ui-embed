{
  "name": "duck-ui-embed",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "lint": "turbo lint",
    "clean": "turbo clean",
    "publish:all": "turbo build && bash scripts/publish.sh",
    "publish:dry": "turbo build && bash scripts/publish.sh --dry-run",
    "generate-keypair": "bun scripts/generate-keypair.ts",
    "generate-license": "bun scripts/generate-license.ts"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5.5",
    "tsup": "^8",
    "vitest": "^2",
    "@types/react": "^19",
    "@types/react-dom": "^19"
  },
  "packageManager": "bun@1.3.9",
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.18"
  }
}
