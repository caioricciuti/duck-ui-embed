{
  "name": "duck-ui-embed",
  "private": true,
  "workspaces": [
    "packages/core",
    "packages/embed",
    "packages/elements",
    "packages/cdn"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
