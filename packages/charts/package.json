{
  "name": "@duck_ui/charts",
  "version": "0.1.4",
  "description": "uPlot-based chart components for React (line, bar, area, pie, sparkline)",
  "author": "Duck-UI",
  "repository": {
    "type": "git",
    "url": "https://github.com/ibero-data/duck-ui-embed",
    "directory": "packages/charts"
  },
  "homepage": "https://github.com/ibero-data/duck-ui-embed",
  "bugs": "https://github.com/ibero-data/duck-ui-embed/issues",
  "keywords": ["duckdb", "analytics", "react", "embed", "dashboard"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "uplot": "^1.6.31"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "license": "Apache-2.0"
}
