{
  "name": "@duck_ui/embed",
  "version": "0.3.2",
  "description": "Drop-in SQL-powered React components backed by DuckDB-WASM",
  "author": "Duck-UI",
  "repository": {
    "type": "git",
    "url": "https://github.com/caioricciuti/duck-ui-embed",
    "directory": "packages/embed"
  },
  "homepage": "https://github.com/caioricciuti/duck-ui-embed",
  "bugs": "https://github.com/caioricciuti/duck-ui-embed/issues",
  "keywords": ["duckdb", "analytics", "react", "embed", "dashboard", "sql", "charts"],
  "sideEffects": ["*.css"],
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@duck_ui/core": "workspace:*",
    "@tanstack/react-table": "^8.21.3",
    "zustand": "^4.5.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@duckdb/duckdb-wasm": ">=1.28.0"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "license": "Apache-2.0"
}
