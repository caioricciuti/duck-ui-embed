{
  "name": "@duck_ui/components",
  "version": "0.1.8",
  "description": "Embeddable analytics React components — tables, filters, KPIs, charts",
  "author": "Duck-UI",
  "repository": {
    "type": "git",
    "url": "https://github.com/ibero-data/duck-ui-embed",
    "directory": "packages/components"
  },
  "homepage": "https://github.com/ibero-data/duck-ui-embed",
  "bugs": "https://github.com/ibero-data/duck-ui-embed/issues",
  "keywords": ["duckdb", "analytics", "react", "embed", "dashboard"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@duck_ui/core": "^0.1.8",
    "@duck_ui/charts": "^0.1.8",
    "@tanstack/react-table": "^8.20.6",
    "@tanstack/react-virtual": "^3.11.2",
    "zustand": "^5"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@duckdb/duckdb-wasm": ">=1.28.0"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "license": "Apache-2.0"
}
