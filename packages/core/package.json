{
  "name": "@duck_ui/core",
  "version": "0.1.5",
  "description": "DuckDB-WASM engine, query executor, and data source management",
  "author": "Duck-UI",
  "repository": {
    "type": "git",
    "url": "https://github.com/ibero-data/duck-ui-embed",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/ibero-data/duck-ui-embed",
  "bugs": "https://github.com/ibero-data/duck-ui-embed/issues",
  "keywords": ["duckdb", "analytics", "react", "embed", "dashboard"],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@duckdb/duckdb-wasm": "1.33.1-dev19.0"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "license": "Apache-2.0"
}
